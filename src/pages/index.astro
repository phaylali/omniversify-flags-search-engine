    "South Sudan": "ss",
    Spain: "es",
    "Sri Lanka": "lk",
    Sudan: "sd",
    Suriname: "sr",
    Sweden: "se",
    Switzerland: "ch",
    Syria: "sy",
    Taiwan: "tw",
    Tajikistan: "tj",
    Tanzania: "tz",
    "United Republic of Tanzania": "tz",
    Thailand: "th",
    "The Bahamas": "bs",
    Togo: "tg",
    "Trinidad and Tobago": "tt",
    Tunisia: "tn",
    Turkey: "tr",
    Turkmenistan: "tm",
    Tuvalu: "tv",
    Uganda: "ug",
    Ukraine: "ua",
    "United Arab Emirates": "ae",
    "United Kingdom": "gb",
    "United States of America": "us",
    Uruguay: "uy",
    Uzbekistan: "uz",
    Vanuatu: "vu",
    "Vatican City": "va",
    Venezuela: "ve",
    Vietnam: "vn",
    Yemen: "ye",
    Zambia: "zm",
    Zimbabwe: "zw",
  };

  function getMatchingFlags() {
    if (activeGroups.has("any")) {
      return flagsData;
    }
    if (activeGroups.size === 0) return [];
    return flagsData.filter((flag) => {
      const cg = flag.colorGroups || {};
      for (const groupName of activeGroups) {
        if (!cg[groupName]) return false;
      }
      return true;
    });
  }

  function updateFlags() {
    const grid = document.getElementById("flagsGrid")!;
    const countEl = document.getElementById("flagCount")!;
    const matching = getMatchingFlags();
    countEl.textContent = `(${matching.length})`;

    if (matching.length === 0) {
      grid.innerHTML = `
        <div class="col-span-full text-center py-10 px-5 text-[#666]">
          <i class="ti ti-flag-off text-5xl mb-3 opacity-40 block"></i>
          <p>${activeGroups.size === 0 ? "Select colors above or click 'Any' to see all flags" : "No flags match all selected colors"}</p>
        </div>`;
      return;
    }

    grid.innerHTML = matching
      .map(
        (flag) => `
      <div class="flag-card bg-[#252540] rounded-lg p-2 text-center transition-all duration-200 aspect-square flex flex-col hover:bg-[#2e2e50] hover:-translate-y-0.5 cursor-pointer" data-code="${flag.code}">
        <img src="/flags-svgs/${flag.code}.svg" alt="${flag.name}" loading="lazy" class="w-full max-h-[50px] object-contain rounded-sm mb-1" />
        <div class="text-[0.65rem] text-[#ddd] leading-tight overflow-hidden text-ellipsis whitespace-nowrap">${flag.name}</div>
        <div class="flex flex-wrap gap-0.75 justify-center mt-auto pt-1">
          ${flag.colors.map((c) => {
            const isLight = isLightColor(c);
            return `<span class="color-chip inline-flex items-center justify-center px-3.5 py-0.5 rounded-full text-[0.55rem] font-mono border border-white/15 min-w-12 h-5.5 overflow-hidden cursor-pointer transition-transform duration-150 hover:scale-110" style="background:${c}" data-color="${c}"><span class="relative z-10 ${isLight ? 'text-[#333]!' : ''} [text-shadow:0_0_2px_rgba(0,0,0,0.8)]">${c}</span></span>`;
          }).join("")}
        </div>
      </div>
    `,
      )
      .join("");

    grid.querySelectorAll(".flag-card").forEach((card) => {
      card.addEventListener("click", () => {
        const code = card.getAttribute("data-code")!;
        const flag = flagsData.find((f) => f.code === code);
        if (flag) openPreview(flag);
      });
    });
  }

  function updateActiveFilters() {
    const container = document.getElementById("activeFilters")!;
    let html = "";

    activeGroups.forEach((g) => {
      const isAny = g === "any";
      const bgStyle = isAny ? `background: linear-gradient(135deg, #CE1126, #FCD116, #009E49, #003DA5)` : `background:${groupColors[g]}`;
      html += `<div class="flex items-center gap-1.5 px-3 py-1.5 bg-[#2a2a4e] rounded-full text-sm">
        <span class="w-4 h-4 rounded-full border border-white/30" style="${bgStyle}"></span>
        <span>${isAny ? "All Flags" : g.charAt(0).toUpperCase() + g.slice(1)}</span>
        <span class="cursor-pointer text-[#888] text-base leading-none px-0.5 hover:text-[#ff6b6b]" data-remove-group="${g}">&times;</span>
      </div>`;
    });

    if (activeGroups.size > 0) {
      html += `<button class="px-3.5 py-1.5 bg-transparent border border-[#ff6b6b] text-[#ff6b6b] rounded-full cursor-pointer text-xs transition-all duration-200 hover:bg-[#ff6b6b] hover:text-white" id="clearAll">Clear All</button>`;
    }

    container.innerHTML = html;

    container.querySelectorAll("[data-remove-group]").forEach((el) => {
      el.addEventListener("click", () => {
        const group = el.getAttribute("data-remove-group")!;
        activeGroups.delete(group);
        document.querySelectorAll(`.color-group-btn[data-group="${group}"]`).forEach((b) => b.classList.remove("active"));
        updateAll();
      });
    });

    document.getElementById("clearAll")?.addEventListener("click", () => {
      activeGroups.clear();
      document.querySelectorAll(".color-group-btn").forEach((el) => el.classList.remove("active"));
      updateAll();
    });
  }

  function updateMap() {
    if (!geoJsonLayer) return;
    const matchingCodes = new Set(getMatchingFlags().map((f) => f.code));

    const svg = document.getElementById("mapSvg")!;
    svg.querySelectorAll("path").forEach((path: any) => {
      const name = path.dataset.name || "";
      const code = nameMap[name];
      if (code && matchingCodes.has(code)) {
        path.setAttribute("fill", "#FFD700");
        path.setAttribute("fill-opacity", "0.7");
      } else {
        path.setAttribute("fill", "#333");
        path.setAttribute("fill-opacity", "0.3");
      }
    });
  }

  function updateAll() {
    updateFlags();
    updateActiveFilters();
    updateMap();
  }

  function openPreview(flag: any) {
    const preview = document.getElementById("flagPreview")!;
    const previewFlag = document.getElementById("previewFlag")!;
    const previewName = document.getElementById("previewName")!;
    const previewColors = document.getElementById("previewColors")!;

    previewFlag.src = `/flags-svgs/${flag.code}.svg`;
    previewFlag.alt = flag.name;
    previewName.textContent = flag.name;
    previewColors.innerHTML = flag.colors
      .map((c: string) => {
        const isLight = isLightColor(c);
        return `<span class="color-chip inline-flex items-center justify-center px-3 py-1.5 rounded-full text-sm min-w-18 cursor-pointer transition-transform duration-150 hover:scale-110" style="background:${c}" data-color="${c}"><span class="relative z-10 ${isLight ? 'text-[#333]!' : 'text-white'} [text-shadow:0_0_2px_rgba(0,0,0,0.8)]">${c}</span></span>`;
      })
      .join("");

    preview.style.display = 'flex';
    document.body.style.overflow = "hidden";
  }

  function closePreview() {
    const preview = document.getElementById("flagPreview")!;
    preview.style.display = 'none';
    document.body.style.overflow = "";
  }

  document.getElementById("previewClose")?.addEventListener("click", closePreview);
  document.getElementById("previewBackdrop")?.addEventListener("click", closePreview);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closePreview();
  });

  function showCopyTooltip(event: MouseEvent, message: string) {
    const tooltip = document.getElementById("copyTooltip")!;
    tooltip.textContent = message;
    tooltip.style.left = `${event.clientX + 10}px`;
    tooltip.style.top = `${event.clientY + 10}px`;
    tooltip.classList.remove("hidden");
    setTimeout(() => tooltip.classList.add("hidden"), 1500);
  }

  document.addEventListener("click", async (e) => {
    const target = e.target as HTMLElement;
    const colorChip = target.closest(".color-chip") as HTMLElement;
    if (!colorChip) return;

    const color = colorChip.getAttribute("data-color")!;
    try {
      await navigator.clipboard.writeText(color);
      showCopyTooltip(e as MouseEvent, "Copied!");
    } catch (err) {
      showCopyTooltip(e as MouseEvent, "Failed to copy");
    }
  });

  document.querySelectorAll("[data-group]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const group = btn.getAttribute("data-group")!;

      if (group === "any") {
        if (activeGroups.has("any")) {
          activeGroups.clear();
          document.querySelectorAll("[data-group]").forEach((b) => b.classList.remove("active"));
        } else {
          activeGroups.clear();
          activeGroups.add("any");
          document.querySelectorAll("[data-group]").forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
        }
      } else {
        if (activeGroups.has("any")) {
          activeGroups.delete("any");
          document.querySelector('[data-group="any"]')?.classList.remove("active");
        }

        if (activeGroups.has(group)) {
          activeGroups.delete(group);
          btn.classList.remove("active");
        } else {
          activeGroups.add(group);
          btn.classList.add("active");
        }
      }
      updateAll();
    });
  });

  async function initMap() {
    const container = document.getElementById("map")!;
    const svg = document.getElementById("mapSvg")!;
    const width = 900;
    const height = 450;

    let scale = 1;
    let translateX = 0;
    let translateY = 0;
    let isPanning = false;
    let startX = 0;
    let startY = 0;

    const updateTransform = () => {
      const g = svg.querySelector("g");
      if (g) {
        g.setAttribute(
          "transform",
          `translate(${translateX},${translateY}) scale(${scale})`,
        );
      }
    };

    container.addEventListener("wheel", (e) => {
      e.preventDefault();
      const delta = e.deltaY > 0 ? 0.9 : 1.1;
      const newScale = Math.max(0.5, Math.min(10, scale * delta));

      const rect = container.getBoundingClientRect();
      const mouseX = e.clientX - rect.left;
      const mouseY = e.clientY - rect.top;

      translateX = mouseX - (mouseX - translateX) * (newScale / scale);
      translateY = mouseY - (mouseY - translateY) * (newScale / scale);
      scale = newScale;

      updateTransform();
    });

    container.addEventListener("mousedown", (e) => {
      isPanning = true;
      startX = e.clientX - translateX;
      startY = e.clientY - translateY;
      (container as HTMLElement).style.cursor = "grabbing";
    });

    window.addEventListener("mousemove", (e) => {
      if (!isPanning) return;
      translateX = e.clientX - startX;
      translateY = e.clientY - startY;
      updateTransform();
    });

    window.addEventListener("mouseup", () => {
      isPanning = false;
      (container as HTMLElement).style.cursor = "grab";
    });

    (container as HTMLElement).style.cursor = "grab";

    const resetBtn = document.createElement("button");
    resetBtn.textContent = "Reset";
    resetBtn.className = "absolute top-2.5 right-2.5 px-3 py-1 bg-[#252540] border border-[#444] text-white rounded cursor-pointer text-xs z-10";
    resetBtn.addEventListener("click", () => {
      scale = 1;
      translateX = 0;
      translateY = 0;
      updateTransform();
    });
    container.appendChild(resetBtn);

    try {
      const res = await fetch("/world.geojson");
      const geoData = await res.json();

      const projection = (lon: number, lat: number) => {
        const x = (lon + 180) * (width / 360);
        const latRad = (lat * Math.PI) / 180;
        const mercN = Math.log(Math.tan(Math.PI / 4 + latRad / 2));
        const y = height / 2 - (width * mercN) / (2 * Math.PI);
        return [x, y];
      };

      const pathFromCoords = (coords: number[][]): string => {
        return coords
          .map(([lon, lat], i) => {
            const [x, y] = projection(lon, lat);
            return `${i === 0 ? "M" : "L"}${x.toFixed(2)},${y.toFixed(2)}`;
          })
          .join(" ");
      };

      const geometryToPath = (geom: any): string => {
        if (geom.type === "Polygon") {
          return geom.coordinates
            .map((ring: number[][]) => pathFromCoords(ring) + "Z")
            .join(" ");
        } else if (geom.type === "MultiPolygon") {
          return geom.coordinates
            .map((polygon: number[][][]) =>
              polygon
                .map((ring: number[][]) => pathFromCoords(ring) + "Z")
                .join(" "),
            )
            .join(" ");
        }
        return "";
      };

      const g = document.createElementNS("http://www.w3.org/2000/svg", "g");

      geoData.features.forEach((feature: any) => {
        const name = feature.properties.ADMIN || feature.properties.NAME || "";
        const pathD = geometryToPath(feature.geometry);

        if (pathD) {
          const path = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "path",
          );
          path.setAttribute("d", pathD);
          path.setAttribute("fill", "#333");
          path.setAttribute("fill-opacity", "0.3");
          path.setAttribute("data-name", name);

          path.addEventListener("mouseenter", () => {
            const tooltip = document.createElement("div");
            tooltip.textContent = name;
            tooltip.className = "fixed bg-[#1a1a2e] text-white px-2 py-1 rounded text-xs pointer-events-none z-[1000] border border-[#444]";
            document.body.appendChild(tooltip);
            (path as any)._tooltip = tooltip;
          });

          path.addEventListener("mousemove", (e) => {
            const tooltip = (path as any)._tooltip;
            if (tooltip) {
              tooltip.style.left = e.clientX + 10 + "px";
              tooltip.style.top = e.clientY + 10 + "px";
            }
          });

          path.addEventListener("mouseleave", () => {
            const tooltip = (path as any)._tooltip;
            if (tooltip) {
              tooltip.remove();
              (path as any)._tooltip = null;
            }
          });

          g.appendChild(path);
        }
      });

      svg.appendChild(g);
      geoJsonLayer = true;
    } catch (e) {
      console.error("Failed to load GeoJSON:", e);
    }
  }

  initMap();
</script>
