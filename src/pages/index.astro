---
import Layout from "../layouts/Layout.astro";
import flagsData from "../../public/flags.json";
import Copyright from "../components/Copyright.astro";

// Color groups - simplified to 7 main groups + "Any" option
const groups = [
  { key: "any", label: "Any", color: "linear-gradient(135deg, #CE1126, #FCD116, #009E49, #003DA5)" },
  { key: "red", label: "Red", color: "#CE1126" },
  { key: "blue", label: "Blue", color: "#003DA5" },
  { key: "green", label: "Green", color: "#009E49" },
  { key: "yellow", label: "Yellow", color: "#FCD116" },
  { key: "orange", label: "Orange", color: "#FF8C00" },
  { key: "white", label: "White", color: "#FFFFFF" },
  { key: "black", label: "Black", color: "#000000" },
];
---

<Layout title="Flag Color Explorer">
  <div class="max-w-7xl mx-auto px-5 py-5">
    <header class="text-center mb-5 py-5 border-b border-[#333]">
      <h1 class="text-4xl bg-gradient-to-br from-[#667eea] to-[#764ba2] bg-clip-text text-transparent mb-2">Flag Color Explorer</h1>
      <p class="text-[#888] text-base">Select colors to find flags containing ALL selected colors, or click "Any" to see all flags</p>
    </header>

    <div class="flex flex-wrap gap-2 mb-5 min-h-10 items-center px-2.5" id="activeFilters"></div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div class="flex flex-col gap-5">
        <section class="bg-[#1a1a2e] rounded-2xl p-5 shadow-lg shadow-black/30" id="colorPalette">
          <div class="flex flex-wrap gap-3 justify-center" id="simplifiedView">
            {groups.map((g) => (
              <button
                class="flex flex-col items-center gap-1.5 p-3 bg-[#252540] border-2 border-transparent rounded-xl cursor-pointer transition-all duration-200 min-w-20 hover:-translate-y-0.5 hover:border-[#667eea] hover:bg-[#2e2e50] [&.active]:border-white [&.active]:bg-[#3a3a5e] [&.active]:shadow-[0_0_15px_rgba(255,255,255,0.2)]"
                data-group={g.key}
                aria-label={`Select ${g.label}`}
              >
                <span
                  class="w-12 h-12 rounded-full border-2 border-white/20"
                  style={`background: ${g.color}`}
                />
                <span class="text-sm font-semibold text-white">{g.label}</span>
              </button>
            ))}
          </div>
        </section>

        <section class="bg-[#1a1a2e] rounded-2xl p-5 shadow-lg shadow-black/30">
          <h2 class="mb-4 text-xl text-white flex items-center gap-2.5">World Map</h2>
          <div id="map" class="h-[350px] rounded-xl overflow-hidden bg-[#0a0a15] relative">
            <svg id="mapSvg" viewBox="0 0 900 450" preserveAspectRatio="xMidYMid meet" class="w-full h-full [&>g>path]:stroke-[#1a1a2e] [&>g>path]:stroke-2 [&>g>path]:cursor-pointer [&>g>path]:transition-[fill] [&>g>path:hover]:fill-opacity-50"></svg>
          </div>
        </section>
      </div>

      <section class="bg-[#1a1a2e] rounded-2xl p-5 shadow-lg shadow-black/30 flex flex-col min-h-0">
        <h2 class="mb-4 text-xl text-white flex items-center gap-2.5">Matching Flags <span id="flagCount" class="text-sm text-[#888] font-normal">(0)</span></h2>
        <div class="flex-1 grid grid-cols-[repeat(auto-fill,minmax(100px,1fr))] gap-2 overflow-y-auto pr-1 [&::-webkit-scrollbar]:w-1 [&::-webkit-scrollbar-track]:bg-[#2a2a3e] [&::-webkit-scrollbar-track]:rounded-sm [&::-webkit-scrollbar-thumb]:bg-[#4a4a6e] [&::-webkit-scrollbar-thumb]:rounded-sm" id="flagsGrid">
          <div class="col-span-full text-center py-10 px-5 text-[#666]">
            <i class="ti ti-flag-off text-5xl mb-3 opacity-40 block"></i>
            <p>Select colors above or click "Any" to see all flags</p>
          </div>
        </div>
      </section>
    </div>

    <Copyright />
  </div>

  <div class="fixed inset-0 hidden z-[1000]" id="flagPreview">
    <div class="absolute inset-0 bg-black/85 backdrop-blur-sm" id="previewBackdrop"></div>
    <div class="flex items-center justify-center w-full h-full relative z-[1001]">
      <div class="bg-[#1a1a2e] rounded-2xl p-10 max-w-3xl w-[90%] text-center shadow-2xl shadow-black/50 animate-[previewIn_0.2s_ease]">
        <button class="absolute top-4 right-4 w-9 h-9 border-none bg-[#333] text-white rounded-full text-2xl cursor-pointer flex items-center justify-center transition-colors duration-200 hover:bg-[#555]" id="previewClose">&times;</button>
        <img id="previewFlag" src="" alt="" class="mx-auto block max-w-full max-h-[400px] object-contain rounded-lg mb-5" />
        <h2 id="previewName" class="text-2xl text-[#e0e0e0] mb-4"></h2>
        <div class="flex flex-wrap gap-2 justify-center" id="previewColors"></div>
      </div>
    </div>
  </div>

  <div id="copyTooltip" class="fixed hidden z-[2000] bg-[#252540] text-white px-3 py-1.5 rounded-md text-sm shadow-lg pointer-events-none"></div>

  <link
    rel="stylesheet"
    href="https://unpkg.com/@tabler/icons-webfont@3.28.1/tabler-icons.min.css"
  />
</Layout>

<script>
  import flagsData from "../../public/flags.json";

  // 7 color groups + "any"
  const groups = ["any", "red", "blue", "green", "yellow", "orange", "white", "black"];
  const groupColors: Record<string, string> = {
    any: "linear-gradient(135deg, #CE1126, #FCD116, #009E49, #003DA5)",
    red: "#CE1126",
    blue: "#003DA5",
    green: "#009E49",
    yellow: "#FCD116",
    orange: "#FF8C00",
    white: "#FFFFFF",
    black: "#000000",
  };

  const activeGroups = new Set<string>();
  let geoJsonLayer: any = null;

  function isLightColor(hex: string): boolean {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return (r * 299 + g * 587 + b * 114) / 1000 > 128;
  }

