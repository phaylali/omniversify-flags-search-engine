  import flagsData from "../../public/flags.json";
  import colorGroupsData from "../../public/colorGroups.json";

  // Build lookup maps
  const groupColors: Record<string, string[]> = {};
  const colorToGroup: Record<string, string> = {};

  Object.entries(colorGroupsData.groups).forEach(([key, group]) => {
    groupColors[key] = group.colors;
    group.colors.forEach((c) => {
      colorToGroup[c.toUpperCase()] = key;
    });
  });

  const activeColors = new Set<string>();
  const activeGroups = new Set<string>();
  let isAdvanced = false;
  let map: any = null;
  let geoJsonLayer: any = null;

