  function getActiveGroupNames(): Set<string> {
    const names = new Set<string>();
    activeGroups.forEach((g) => names.add(g));
    activeColors.forEach((c) => {
      const g = colorToGroup[c.toUpperCase()];
      if (g) names.add(g);
    });
    return names;
  }

  function getMatchingFlags() {
    // Advanced mode: AND logic for specific hex colors
    if (isAdvanced) {
      if (activeColors.size === 0) return [];
      return flagsData.filter((flag) => {
        const flagColors = flag.colors.map((c) => c.toUpperCase());
        for (const color of activeColors) {
          if (!flagColors.includes(color.toUpperCase())) return false;
        }
        return true;
      });
    }

    // Simplified mode: AND logic across groups
    const groupNames = getActiveGroupNames();
    if (groupNames.size === 0) return [];

    return flagsData.filter((flag) => {
      const flagColors = flag.colors.map((c) => c.toUpperCase());
      for (const groupName of groupNames) {
        const groupColorList = groupColors[groupName] || [];
        const hasMatch = groupColorList.some((gc) =>
          flagColors.includes(gc.toUpperCase()),
        );
        if (!hasMatch) return false;
      }
      return true;
    });
  }

  function updateFlags() {
    const grid = document.getElementById("flagsGrid")!;
    const countEl = document.getElementById("flagCount")!;
    const matching = getMatchingFlags();
    countEl.textContent = `(${matching.length})`;

    if (matching.length === 0) {
      grid.innerHTML = `
        <div class="no-flags">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" />
          </svg>
          <p>${activeColors.size === 0 && activeGroups.size === 0 ? "Select colors above to see matching flags" : "No flags match all selected colors"}</p>
        </div>`;
      return;
    }

    grid.innerHTML = matching
      .map(
        (flag) => `
      <div class="flag-card">
        <img src="https://flagcdn.com/w320/${flag.code}.png" alt="${flag.name}" loading="lazy" />
        <div class="country-name">${flag.name}</div>
        <div class="flag-colors">
          ${flag.colors.map((c) => `<div class="flag-color-dot" style="background:${c}"></div>`).join("")}
        </div>
      </div>
    `,
      )
      .join("");
  }

  function updateActiveFilters() {
    const container = document.getElementById("activeFilters")!;
    let html = "";

    activeGroups.forEach((g) => {
      const colors = groupColors[g] || [];
      const groupInfo = (colorGroupsData as any).groups[g];
      html += `<div class="filter-tag">
        <span class="dot" style="background:${colors[0] || "#888"}"></span>
        <span>${groupInfo?.label || g}</span>
        <span class="remove" data-remove-group="${g}">&times;</span>
      </div>`;
    });

    activeColors.forEach((c) => {
      const group = colorToGroup[c.toUpperCase()];
      if (!activeGroups.has(group)) {
        html += `<div class="filter-tag">
          <span class="dot" style="background:${c}"></span>
          <span>${c}</span>
          <span class="remove" data-remove-color="${c}">&times;</span>
        </div>`;
      }
    });

    if (activeGroups.size > 0 || activeColors.size > 0) {
      html += `<button class="clear-all" id="clearAll">Clear All</button>`;
    }

    container.innerHTML = html;

    container.querySelectorAll("[data-remove-group]").forEach((el) => {
      el.addEventListener("click", () => {
        const group = el.getAttribute("data-remove-group")!;
        activeGroups.delete(group);
        document
          .querySelectorAll(`.color-group-btn[data-group="${group}"]`)
          .forEach((b) => b.classList.remove("active"));
        updateAll();
      });
    });

    container.querySelectorAll("[data-remove-color]").forEach((el) => {
      el.addEventListener("click", () => {
        const color = el.getAttribute("data-remove-color")!;
        activeColors.delete(color);
        document
          .querySelectorAll(`.color-swatch[data-color="${color}"]`)
          .forEach((b) => b.classList.remove("active"));
        updateAll();
      });
    });

    document.getElementById("clearAll")?.addEventListener("click", () => {
      activeColors.clear();
      activeGroups.clear();
      document
        .querySelectorAll(".active")
        .forEach((el) => el.classList.remove("active"));
      updateAll();
    });
  }

  function updateMap() {
    if (!geoJsonLayer) return;
    const matchingCodes = new Set(getMatchingFlags().map((f) => f.code));

    geoJsonLayer.eachLayer((layer: any) => {
      const name =
        layer.feature.properties.ADMIN || layer.feature.properties.name || "";
      const code = nameMap[name];
      if (code && matchingCodes.has(code)) {
        layer.setStyle({
          fillColor: "#FFD700",
          fillOpacity: 0.7,
          weight: 2,
          color: "#FFD700",
        });
      } else {
        layer.setStyle({
          fillColor: "#333",
          fillOpacity: 0.2,
          weight: 1,
          color: "#555",
        });
      }
    });
  }

  function updateAll() {
    updateFlags();
    updateActiveFilters();
    updateMap();
  }

  // View toggle
  document.getElementById("simplifiedBtn")!.addEventListener("click", () => {
    isAdvanced = false;
    document.getElementById("simplifiedView")!.classList.remove("hidden");
    document.getElementById("advancedView")!.classList.add("hidden");
    document.getElementById("simplifiedBtn")!.classList.add("active");
    document.getElementById("advancedBtn")!.classList.remove("active");
    updateAll();
  });

  document.getElementById("advancedBtn")!.addEventListener("click", () => {
    isAdvanced = true;
    document.getElementById("advancedView")!.classList.remove("hidden");
    document.getElementById("simplifiedView")!.classList.add("hidden");
    document.getElementById("advancedBtn")!.classList.add("active");
    document.getElementById("simplifiedBtn")!.classList.remove("active");
    updateAll();
  });

  // Simplified: group buttons
  document.querySelectorAll(".color-group-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const group = btn.getAttribute("data-group")!;
      if (activeGroups.has(group)) {
        activeGroups.delete(group);
        btn.classList.remove("active");
      } else {
        activeGroups.add(group);
        btn.classList.add("active");
      }
      updateAll();
    });
  });

  // Advanced: individual swatches
  document.querySelectorAll(".color-swatch").forEach((swatch) => {
    swatch.addEventListener("click", () => {
      const color = swatch.getAttribute("data-color")!;
      if (activeColors.has(color)) {
        activeColors.delete(color);
        swatch.classList.remove("active");
      } else {
        activeColors.add(color);
        swatch.classList.add("active");
      }
      updateAll();
    });
  });

  // Map
  function waitForLeaflet() {
    if (typeof (window as any).L !== "undefined") initMap();
    else setTimeout(waitForLeaflet, 100);
  }

  async function initMap() {
    const L = (window as any).L;
    map = L.map("map").setView([20, 0], 2);
    L.tileLayer(
      "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png",
      {
        attribution: "&copy; OpenStreetMap contributors &copy; CARTO",
        maxZoom: 19,
      },
    ).addTo(map);

    try {
      const res = await fetch(
        "https://raw.githubusercontent.com/datasets/geo-countries/master/data/countries.geojson",
      );
      const geoData = await res.json();
      // Filter out excluded countries
      const excludedCountries = ["Israel", "Western Sahara"];
      geoData.features = geoData.features.filter(
        (f: any) =>
          !excludedCountries.includes(f.properties.ADMIN) &&
          !excludedCountries.includes(f.properties.name),
      );
      geoJsonLayer = L.geoJSON(geoData, {
        style: {
          fillColor: "#333",
          fillOpacity: 0.2,
          weight: 1,
          color: "#555",
        },
        onEachFeature: (feature: any, layer: any) => {
          layer.bindTooltip(
            feature.properties.ADMIN || feature.properties.name || "Unknown",
          );
        },
      }).addTo(map);
    } catch (e) {
      console.error("Failed to load GeoJSON:", e);
    }
  }

  waitForLeaflet();
</script>
