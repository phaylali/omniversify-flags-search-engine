---
import Layout from "../layouts/Layout.astro";
import flagsData from "../../public/flags.json";

// Color groups - simplified to 7 main groups + "Any" option
const groups = [
  { key: "any", label: "Any", color: "linear-gradient(135deg, #CE1126, #FCD116, #009E49, #003DA5)" },
  { key: "red", label: "Red", color: "#CE1126" },
  { key: "blue", label: "Blue", color: "#003DA5" },
  { key: "green", label: "Green", color: "#009E49" },
  { key: "yellow", label: "Yellow", color: "#FCD116" },
  { key: "orange", label: "Orange", color: "#FF8C00" },
  { key: "white", label: "White", color: "#FFFFFF" },
  { key: "black", label: "Black", color: "#000000" },
];
---

<Layout title="Flag Color Explorer">
  <div class="container">
    <header>
      <h1>Flag Color Explorer</h1>
      <p>Select colors to find flags containing ALL selected colors, or click "Any" to see all flags</p>
    </header>

    <div class="active-filters" id="activeFilters"></div>

    <div class="main-content">
      <div class="left-column">
        <section class="color-palette" id="colorPalette">
          <!-- Color group buttons -->
          <div id="simplifiedView" class="palette-view">
            {groups.map((g) => (
              <button
                class="color-group-btn"
                data-group={g.key}
                aria-label={`Select ${g.label}`}
              >
                <span
                  class="group-swatch"
                  style={`background-color: ${g.color}`}
                />
                <span class="group-label">{g.label}</span>
              </button>
            ))}
          </div>
        </section>

        <section class="map-section">
          <h2>World Map</h2>
          <div id="map">
            <svg id="mapSvg" viewBox="0 0 900 450" preserveAspectRatio="xMidYMid meet"></svg>
          </div>
        </section>
      </div>

      <section class="flags-section">
        <h2>Matching Flags <span id="flagCount">(0)</span></h2>
        <div class="flags-grid" id="flagsGrid">
          <div class="no-flags">
            <i class="ti ti-flag-off"></i>
            <p>Select colors above or click "Any" to see all flags</p>
          </div>
        </div>
      </section>
    </div>
  </div>

  <div class="flag-preview" id="flagPreview">
    <div class="preview-backdrop" id="previewBackdrop"></div>
    <div class="preview-content">
      <button class="preview-close" id="previewClose">&times;</button>
      <img id="previewFlag" src="" alt="" />
      <h2 id="previewName"></h2>
      <div class="preview-colors" id="previewColors"></div>
    </div>
  </div>

  <link
    rel="stylesheet"
    href="https://unpkg.com/@tabler/icons-webfont@3.28.1/tabler-icons.min.css"
  />
</Layout>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: #0f0f1a;
    color: #e0e0e0;
    min-height: 100vh;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px;
  }

  header {
    text-align: center;
    margin-bottom: 20px;
    padding: 20px 0;
    border-bottom: 1px solid #333;
  }

  header h1 {
    font-size: 2.5rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
  }

  header p {
    color: #888;
    font-size: 1rem;
  }

  .view-toggle {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .toggle-btn {
    padding: 10px 24px;
    border: 2px solid #444;
    background: #1a1a2e;
    color: #aaa;
    border-radius: 25px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .toggle-btn:hover {
    border-color: #667eea;
    color: #fff;
  }
  .toggle-btn.active {
    background: #667eea;
    border-color: #667eea;
    color: #fff;
  }

  .color-palette {
    background: #1a1a2e;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .hidden {
    display: none !important;
  }

  #simplifiedView {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .color-group-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    background: #252540;
    border: 2px solid transparent;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
    min-width: 80px;
  }

  .color-group-btn:hover {
    transform: translateY(-2px);
    border-color: #667eea;
    background: #2e2e50;
  }

  .color-group-btn.active {
    border-color: #fff;
    background: #3a3a5e;
    box-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
  }

  .group-swatch {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.2);
  }

  .group-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
  }
  .group-count {
    font-size: 0.7rem;
    color: #888;
  }

  #advancedView {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .color-group-section {
    background: #252540;
    border-radius: 12px;
    padding: 12px;
  }

  .group-header {
    font-size: 0.9rem;
    font-weight: 600;
    color: #aaa;
    margin-bottom: 8px;
    padding-left: 4px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .group-colors {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .color-swatch {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 2px solid transparent;
  }

  .color-swatch:hover {
    transform: scale(1.15);
  }
  .color-swatch.active {
    border-color: #fff;
    transform: scale(1.1);
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.4);
  }

  .active-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
    min-height: 40px;
    align-items: center;
  }

  .filter-tag {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: #2a2a4e;
    border-radius: 20px;
    font-size: 0.85rem;
  }

  .filter-tag .dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .filter-tag .remove {
    cursor: pointer;
    color: #888;
    font-size: 1.1rem;
    line-height: 1;
    padding: 0 2px;
  }

  .filter-tag .remove:hover {
    color: #ff6b6b;
  }

  .clear-all {
    padding: 6px 14px;
    background: transparent;
    border: 1px solid #ff6b6b;
    color: #ff6b6b;
    border-radius: 20px;
    cursor: pointer;
    font-size: 0.8rem;
    transition: all 0.2s;
  }

  .clear-all:hover {
    background: #ff6b6b;
    color: #fff;
  }

  .main-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }

  .left-column {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (max-width: 1024px) {
    .main-content {
      grid-template-columns: 1fr;
    }
  }

  .flags-section,
  .map-section {
    background: #1a1a2e;
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .flags-section {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .flags-section .flags-grid {
    flex: 1;
  }

  .color-palette {
    background: #1a1a2e;
    border-radius: 16px;
    padding: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .flags-section h2,
  .map-section h2 {
    margin-bottom: 16px;
    font-size: 1.3rem;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #flagCount {
    font-size: 0.9rem;
    color: #888;
    font-weight: normal;
  }

  .flags-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 8px;
    overflow-y: auto;
    padding-right: 4px;
  }

  .flags-grid::-webkit-scrollbar {
    width: 4px;
  }
  .flags-grid::-webkit-scrollbar-track {
    background: #2a2a3e;
    border-radius: 2px;
  }
  .flags-grid::-webkit-scrollbar-thumb {
    background: #4a4a6e;
    border-radius: 2px;
  }

  .flag-card {
    background: #252540;
    border-radius: 8px;
    padding: 8px 6px;
    text-align: center;
    transition: all 0.2s ease;
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
  }

  .flag-card:hover {
    background: #2e2e50;
    transform: translateY(-2px);
  }

  .flag-card img {
    width: 100%;
    max-height: 50px;
    object-fit: contain;
    border-radius: 3px;
    margin-bottom: 4px;
  }

  .flag-card .country-name {
    font-size: 0.65rem;
    color: #ddd;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .flag-colors {
    display: flex;
    flex-wrap: wrap;
    gap: 3px;
    justify-content: center;
    margin-top: auto;
    padding-top: 4px;
  }

  .color-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 3px 14px 3px 4px;
    border-radius: 9999px;
    font-size: 0.55rem;
    font-family: monospace;
    border: 1px solid rgba(255, 255, 255, 0.15);
    min-width: 48px;
    height: 22px;
    overflow: hidden;
  }

  .color-hex {
    position: relative;
    z-index: 1;
    text-shadow: 0 0 2px rgba(0, 0, 0, 0.8);
  }

  .dark-text {
    color: #333 !important;
    text-shadow: none;
  }

  /* Adjust text color based on background brightness */
  .color-chip[style*="background:#FFFFFF"],
  .color-chip[style*="background:#ffffff"],
  .color-chip[style*="background:#FCD116"],
  .color-chip[style*="background:#fcd116"],
  .color-chip[style*="background:#FF8C00"],
  .color-chip[style*="background:#ff8c00"] {
    color: #333;
  }

  #map {
    height: 350px;
    border-radius: 12px;
    overflow: hidden;
    background: #0a0a15;
  }

  #mapSvg {
    width: 100%;
    height: 100%;
  }

  #mapSvg path {
    stroke: #1a1a2e;
    stroke-width: 2;
    cursor: pointer;
    transition: fill 0.2s ease;
  }

  #mapSvg path:hover {
    fill-opacity: 0.5 !important;
  }

  .no-flags {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 20px;
    color: #666;
  }

  .no-flags .ti {
    font-size: 48px;
    margin-bottom: 12px;
    opacity: 0.4;
  }

  /* Flag Preview Modal */
  .flag-preview {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .flag-preview.active {
    display: flex;
  }

  .preview-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
  }

  .preview-content {
    position: relative;
    z-index: 1001;
    background: #1a1a2e;
    border-radius: 16px;
    padding: 40px;
    max-width: 800px;
    width: 90%;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    animation: previewIn 0.2s ease;
  }

  @keyframes previewIn {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .preview-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    border: none;
    background: #333;
    color: #fff;
    border-radius: 50%;
    font-size: 24px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .preview-close:hover {
    background: #555;
  }

  .preview-content img {
    max-width: 100%;
    max-height: 400px;
    object-fit: contain;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .preview-content h2 {
    font-size: 1.5rem;
    color: #e0e0e0;
    margin-bottom: 16px;
  }

  .preview-colors {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }

  .preview-colors .color-chip {
    padding: 6px 12px;
    font-size: 0.85rem;
    min-width: 72px;
    border-radius: 999px;
  }
</style>

