  function getActiveGroupNames(): Set<string> {
    const names = new Set<string>();
    activeGroups.forEach((g) => names.add(g));
    activeColors.forEach((c) => {
      const g = colorToGroup[c.toUpperCase()];
      if (g) names.add(g);
    });
    return names;
  }

  function getMatchingFlags() {
    // Advanced mode: AND logic for specific hex colors
    if (isAdvanced) {
      if (activeColors.size === 0) return [];
      return flagsData.filter((flag) => {
        const flagColors = flag.colors.map((c) => c.toUpperCase());
        for (const color of activeColors) {
          if (!flagColors.includes(color.toUpperCase())) return false;
        }
        return true;
      });
    }

    // Simplified mode: AND logic across groups
    const groupNames = getActiveGroupNames();
    if (groupNames.size === 0) return [];

    return flagsData.filter((flag) => {
      const flagColors = flag.colors.map((c) => c.toUpperCase());
      for (const groupName of groupNames) {
        const groupColorList = groupColors[groupName] || [];
        const hasMatch = groupColorList.some((gc) =>
          flagColors.includes(gc.toUpperCase()),
        );
        if (!hasMatch) return false;
      }
      return true;
    });
  }

  function updateFlags() {
    const grid = document.getElementById("flagsGrid")!;
    const countEl = document.getElementById("flagCount")!;
    const matching = getMatchingFlags();
    countEl.textContent = `(${matching.length})`;

    if (matching.length === 0) {
      grid.innerHTML = `
        <div class="no-flags">
          <i class="ti ti-flag-off"></i>
          <p>${activeColors.size === 0 && activeGroups.size === 0 ? "Select colors above to see matching flags" : "No flags match all selected colors"}</p>
        </div>`;
      return;
    }

    grid.innerHTML = matching
      .map(
        (flag) => `
      <div class="flag-card">
        <img src="https://flagicons.lipis.dev/flags/4x3/${flag.code}.svg" alt="${flag.name}" loading="lazy" />
        <div class="country-name">${flag.name}</div>
        <div class="flag-colors">
          ${flag.colors.map((c) => `<div class="flag-color-dot" style="background:${c}"></div>`).join("")}
        </div>
      </div>
    `,
      )
      .join("");
  }

  function updateActiveFilters() {
    const container = document.getElementById("activeFilters")!;
    let html = "";

    activeGroups.forEach((g) => {
      const colors = groupColors[g] || [];
      const groupInfo = (colorGroupsData as any).groups[g];
      html += `<div class="filter-tag">
        <span class="dot" style="background:${colors[0] || "#888"}"></span>
        <span>${groupInfo?.label || g}</span>
        <span class="remove" data-remove-group="${g}">&times;</span>
      </div>`;
    });

    activeColors.forEach((c) => {
      const group = colorToGroup[c.toUpperCase()];
      if (!activeGroups.has(group)) {
        html += `<div class="filter-tag">
          <span class="dot" style="background:${c}"></span>
          <span>${c}</span>
          <span class="remove" data-remove-color="${c}">&times;</span>
        </div>`;
      }
    });

    if (activeGroups.size > 0 || activeColors.size > 0) {
      html += `<button class="clear-all" id="clearAll">Clear All</button>`;
    }

    container.innerHTML = html;

    container.querySelectorAll("[data-remove-group]").forEach((el) => {
      el.addEventListener("click", () => {
        const group = el.getAttribute("data-remove-group")!;
        activeGroups.delete(group);
        document
          .querySelectorAll(`.color-group-btn[data-group="${group}"]`)
          .forEach((b) => b.classList.remove("active"));
        updateAll();
      });
    });

    container.querySelectorAll("[data-remove-color]").forEach((el) => {
      el.addEventListener("click", () => {
        const color = el.getAttribute("data-remove-color")!;
        activeColors.delete(color);
        document
          .querySelectorAll(`.color-swatch[data-color="${color}"]`)
          .forEach((b) => b.classList.remove("active"));
        updateAll();
      });
    });

    document.getElementById("clearAll")?.addEventListener("click", () => {
      activeColors.clear();
      activeGroups.clear();
      document
        .querySelectorAll(".active")
        .forEach((el) => el.classList.remove("active"));
      updateAll();
    });
  }

  function updateMap() {
    if (!geoJsonLayer) return;
    const matchingCodes = new Set(getMatchingFlags().map((f) => f.code));

    const svg = document.getElementById("mapSvg")!;
    svg.querySelectorAll("path").forEach((path: any) => {
      const name = path.dataset.name || "";
      const code = nameMap[name];
      if (code && matchingCodes.has(code)) {
        path.setAttribute("fill", "#FFD700");
        path.setAttribute("fill-opacity", "0.7");
      } else {
        path.setAttribute("fill", "#333");
        path.setAttribute("fill-opacity", "0.3");
      }
    });
  }

  function updateAll() {
    updateFlags();
    updateActiveFilters();
    updateMap();
  }

  // View toggle
  document.getElementById("simplifiedBtn")!.addEventListener("click", () => {
    isAdvanced = false;
    document.getElementById("simplifiedView")!.classList.remove("hidden");
    document.getElementById("advancedView")!.classList.add("hidden");
    document.getElementById("simplifiedBtn")!.classList.add("active");
    document.getElementById("advancedBtn")!.classList.remove("active");
    updateAll();
  });

  document.getElementById("advancedBtn")!.addEventListener("click", () => {
    isAdvanced = true;
    document.getElementById("advancedView")!.classList.remove("hidden");
    document.getElementById("simplifiedView")!.classList.add("hidden");
    document.getElementById("advancedBtn")!.classList.add("active");
    document.getElementById("simplifiedBtn")!.classList.remove("active");
    updateAll();
  });

  // Simplified: group buttons
  document.querySelectorAll(".color-group-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const group = btn.getAttribute("data-group")!;
      if (activeGroups.has(group)) {
        activeGroups.delete(group);
        btn.classList.remove("active");
      } else {
        activeGroups.add(group);
        btn.classList.add("active");
      }
      updateAll();
    });
  });

  // Advanced: individual swatches
  document.querySelectorAll(".color-swatch").forEach((swatch) => {
    swatch.addEventListener("click", () => {
      const color = swatch.getAttribute("data-color")!;
      if (activeColors.has(color)) {
        activeColors.delete(color);
        swatch.classList.remove("active");
      } else {
        activeColors.add(color);
        swatch.classList.add("active");
      }
      updateAll();
    });
  });

  // D3 SVG Map
  async function initMap() {
    const container = document.getElementById("map")!;
    const svg = document.getElementById("mapSvg")!;
    const width = 900;
    const height = 450;

    let scale = 1;
    let translateX = 0;
    let translateY = 0;
    let isPanning = false;
    let startX = 0;
    let startY = 0;

    const updateTransform = () => {
      const g = svg.querySelector("g");
      if (g) {
        g.setAttribute(
          "transform",
          `translate(${translateX},${translateY}) scale(${scale})`,
        );
      }
    };

    // Zoom with mouse wheel
    container.addEventListener("wheel", (e) => {
      e.preventDefault();
      const delta = e.deltaY > 0 ? 0.9 : 1.1;
      const newScale = Math.max(0.5, Math.min(10, scale * delta));

      // Zoom toward mouse position
      const rect = container.getBoundingClientRect();
      const mouseX = e.clientX - rect.left;
      const mouseY = e.clientY - rect.top;

      translateX = mouseX - (mouseX - translateX) * (newScale / scale);
      translateY = mouseY - (mouseY - translateY) * (newScale / scale);
      scale = newScale;

      updateTransform();
    });

    // Pan with mouse drag
    container.addEventListener("mousedown", (e) => {
      isPanning = true;
      startX = e.clientX - translateX;
      startY = e.clientY - translateY;
      container.style.cursor = "grabbing";
    });

    window.addEventListener("mousemove", (e) => {
      if (!isPanning) return;
      translateX = e.clientX - startX;
      translateY = e.clientY - startY;
      updateTransform();
    });

    window.addEventListener("mouseup", () => {
      isPanning = false;
      container.style.cursor = "grab";
    });

    container.style.cursor = "grab";

    // Reset zoom button
    const resetBtn = document.createElement("button");
    resetBtn.textContent = "Reset";
    resetBtn.style.cssText = `
      position: absolute;
      top: 10px;
      right: 10px;
      padding: 4px 12px;
      background: #252540;
      border: 1px solid #444;
      color: #fff;
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
      z-index: 10;
    `;
    resetBtn.addEventListener("click", () => {
      scale = 1;
      translateX = 0;
      translateY = 0;
      updateTransform();
    });
    container.style.position = "relative";
    container.appendChild(resetBtn);

    try {
      const res = await fetch("/world.geojson");
      const geoData = await res.json();

      // Simple mercator projection
      const projection = (lon: number, lat: number) => {
        const x = (lon + 180) * (width / 360);
        const latRad = (lat * Math.PI) / 180;
        const mercN = Math.log(Math.tan(Math.PI / 4 + latRad / 2));
        const y = height / 2 - (width * mercN) / (2 * Math.PI);
        return [x, y];
      };

      const pathFromCoords = (coords: number[][]): string => {
        return coords
          .map(([lon, lat], i) => {
            const [x, y] = projection(lon, lat);
            return `${i === 0 ? "M" : "L"}${x.toFixed(2)},${y.toFixed(2)}`;
          })
          .join(" ");
      };

      const geometryToPath = (geom: any): string => {
        if (geom.type === "Polygon") {
          return geom.coordinates
            .map((ring: number[][]) => pathFromCoords(ring) + "Z")
            .join(" ");
        } else if (geom.type === "MultiPolygon") {
          return geom.coordinates
            .map((polygon: number[][][]) =>
              polygon
                .map((ring: number[][]) => pathFromCoords(ring) + "Z")
                .join(" "),
            )
            .join(" ");
        }
        return "";
      };

      const g = document.createElementNS("http://www.w3.org/2000/svg", "g");

      geoData.features.forEach((feature: any) => {
        const name = feature.properties.ADMIN || feature.properties.NAME || "";
        const pathD = geometryToPath(feature.geometry);

        if (pathD) {
          const path = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "path",
          );
          path.setAttribute("d", pathD);
          path.setAttribute("fill", "#333");
          path.setAttribute("fill-opacity", "0.3");
          path.setAttribute("data-name", name);

          // Tooltip
          path.addEventListener("mouseenter", (e) => {
            const tooltip = document.createElement("div");
            tooltip.className = "map-tooltip";
            tooltip.textContent = name;
            tooltip.style.cssText = `
              position: fixed;
              background: #1a1a2e;
              color: #fff;
              padding: 4px 8px;
              border-radius: 4px;
              font-size: 12px;
              pointer-events: none;
              z-index: 1000;
              border: 1px solid #444;
            `;
            document.body.appendChild(tooltip);
            (path as any)._tooltip = tooltip;
          });

          path.addEventListener("mousemove", (e) => {
            const tooltip = (path as any)._tooltip;
            if (tooltip) {
              tooltip.style.left = e.clientX + 10 + "px";
              tooltip.style.top = e.clientY + 10 + "px";
            }
          });

          path.addEventListener("mouseleave", () => {
            const tooltip = (path as any)._tooltip;
            if (tooltip) {
              tooltip.remove();
              (path as any)._tooltip = null;
            }
          });

          g.appendChild(path);
        }
      });

      svg.appendChild(g);
      geoJsonLayer = true;
    } catch (e) {
      console.error("Failed to load GeoJSON:", e);
    }
  }

  initMap();
</script>
