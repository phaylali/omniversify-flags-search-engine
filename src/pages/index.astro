---
import Layout from "../layouts/Layout.astro";
import flagsData from "../../public/flags.json";
import colorGroupsData from "../../public/colorGroups.json";

// Build grouped colors for display
const groups = Object.entries(colorGroupsData.groups)
  .filter(([_, g]) => g.colors.length > 0)
  .map(([key, g]) => ({
    key,
    label: g.label,
    colors: g.colors,
  }));
---

<Layout title="Flag Color Explorer">
  <div class="container">
    <header>
      <h1>Flag Color Explorer</h1>
      <p>Select colors to find flags containing ALL selected colors</p>
    </header>

    <div class="view-toggle">
      <button class="toggle-btn active" id="simplifiedBtn">Simplified</button>
      <button class="toggle-btn" id="advancedBtn">Advanced</button>
    </div>

    <div class="active-filters" id="activeFilters"></div>

    <div class="main-content">
      <div class="left-column">
        <section class="color-palette" id="colorPalette">
          <!-- Simplified view -->
          <div id="simplifiedView" class="palette-view">
            {
              groups.map((g) => (
                <button
                  class="color-group-btn"
                  data-group={g.key}
                  aria-label={`Select ${g.label}`}
                >
                  <span
                    class="group-swatch"
                    style={`background: linear-gradient(135deg, ${g.colors[0]} 0%, ${g.colors[Math.floor(g.colors.length / 2)]} 50%, ${g.colors[g.colors.length - 1]} 100%)`}
                  />
                  <span class="group-label">{g.label}</span>
                  <span class="group-count">({g.colors.length})</span>
                </button>
              ))
            }
          </div>

          <!-- Advanced view -->
          <div id="advancedView" class="palette-view hidden">
            {
              groups.map((g) => (
                <div class="color-group-section" data-group-section={g.key}>
                  <div class="group-header">{g.label}</div>
                  <div class="group-colors">
                    {g.colors.map((color) => (
                      <button
                        class="color-swatch"
                        style={`background-color: ${color}`}
                        data-color={color}
                        data-group={g.key}
                        title={color}
                        aria-label={`Select color ${color}`}
                      />
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </section>

        <section class="map-section">
          <h2>World Map</h2>
          <div id="map"></div>
        </section>
      </div>

      <section class="flags-section">
        <h2>Matching Flags <span id="flagCount">(0)</span></h2>
        <div class="flags-grid" id="flagsGrid">
          <div class="no-flags">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"
              ></path>
            </svg>
            <p>Select colors above to see matching flags</p>
          </div>
        </div>
      </section>
    </div>
  </div>

  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  ></script>
</Layout>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: #0f0f1a;
    color: #e0e0e0;
    min-height: 100vh;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px;
  }

  header {
    text-align: center;
    margin-bottom: 20px;
    padding: 20px 0;
    border-bottom: 1px solid #333;
  }

  header h1 {
    font-size: 2.5rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 8px;
  }

  header p {
    color: #888;
    font-size: 1rem;
  }

  .view-toggle {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .toggle-btn {
    padding: 10px 24px;
    border: 2px solid #444;
    background: #1a1a2e;
    color: #aaa;
    border-radius: 25px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .toggle-btn:hover {
    border-color: #667eea;
    color: #fff;
  }
  .toggle-btn.active {
    background: #667eea;
    border-color: #667eea;
    color: #fff;
  }

  .color-palette {
    background: #1a1a2e;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .hidden {
    display: none !important;
  }

  #simplifiedView {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .color-group-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    background: #252540;
    border: 2px solid transparent;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
    min-width: 80px;
  }

  .color-group-btn:hover {
    transform: translateY(-2px);
    border-color: #667eea;
    background: #2e2e50;
  }

  .color-group-btn.active {
    border-color: #fff;
    background: #3a3a5e;
    box-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
  }

  .group-swatch {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.2);
  }

  .group-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
  }
  .group-count {
    font-size: 0.7rem;
    color: #888;
  }

  #advancedView {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .color-group-section {
    background: #252540;
    border-radius: 12px;
    padding: 12px;
  }

  .group-header {
    font-size: 0.9rem;
    font-weight: 600;
    color: #aaa;
    margin-bottom: 8px;
    padding-left: 4px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .group-colors {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .color-swatch {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 2px solid transparent;
  }

  .color-swatch:hover {
    transform: scale(1.15);
  }
  .color-swatch.active {
    border-color: #fff;
    transform: scale(1.1);
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.4);
  }

  .active-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
    min-height: 40px;
    align-items: center;
  }

  .filter-tag {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: #2a2a4e;
    border-radius: 20px;
    font-size: 0.85rem;
  }

  .filter-tag .dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .filter-tag .remove {
    cursor: pointer;
    color: #888;
    font-size: 1.1rem;
    line-height: 1;
    padding: 0 2px;
  }

  .filter-tag .remove:hover {
    color: #ff6b6b;
  }

  .clear-all {
    padding: 6px 14px;
    background: transparent;
    border: 1px solid #ff6b6b;
    color: #ff6b6b;
    border-radius: 20px;
    cursor: pointer;
    font-size: 0.8rem;
    transition: all 0.2s;
  }

  .clear-all:hover {
    background: #ff6b6b;
    color: #fff;
  }

  .main-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }

  .left-column {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (max-width: 1024px) {
    .main-content {
      grid-template-columns: 1fr;
    }
  }

  .flags-section,
  .map-section {
    background: #1a1a2e;
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .flags-section {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .flags-section .flags-grid {
    flex: 1;
  }

  .color-palette {
    background: #1a1a2e;
    border-radius: 16px;
    padding: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .flags-section h2,
  .map-section h2 {
    margin-bottom: 16px;
    font-size: 1.3rem;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #flagCount {
    font-size: 0.9rem;
    color: #888;
    font-weight: normal;
  }

  .flags-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 8px;
    overflow-y: auto;
    padding-right: 4px;
  }

  .flags-grid::-webkit-scrollbar {
    width: 4px;
  }
  .flags-grid::-webkit-scrollbar-track {
    background: #2a2a3e;
    border-radius: 2px;
  }
  .flags-grid::-webkit-scrollbar-thumb {
    background: #4a4a6e;
    border-radius: 2px;
  }

  .flag-card {
    background: #252540;
    border-radius: 8px;
    padding: 8px 6px;
    text-align: center;
    transition: all 0.2s ease;
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
  }

  .flag-card:hover {
    background: #2e2e50;
    transform: translateY(-2px);
  }

  .flag-card img {
    width: 100%;
    max-height: 50px;
    object-fit: contain;
    border-radius: 3px;
    margin-bottom: 4px;
  }

  .flag-card .country-name {
    font-size: 0.65rem;
    color: #ddd;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .flag-colors {
    display: flex;
    gap: 2px;
    justify-content: center;
    margin-top: auto;
    padding-top: 3px;
  }
  .flag-color-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  #map {
    height: 350px;
    border-radius: 12px;
    overflow: hidden;
  }

  .no-flags {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 20px;
    color: #666;
  }

  .no-flags svg {
    width: 50px;
    height: 50px;
    margin-bottom: 12px;
    opacity: 0.3;
  }
</style>

