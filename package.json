{
  "name": "flagssearchengine",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "download-flags": "bash scripts/download-flags.sh",
    "filter-svgs": "bash scripts/filter-svgs.sh",
    "extract-colors": "bun run scripts/extract-svg-colors.ts",
    "filter-countries": "bun run scripts/filter-countries.ts",
    "classify-colors": "bun run scripts/classify-colors.ts",
    "generate-color-map": "bun run scripts/generate-color-map.ts",
    "normalize-colors": "bun run scripts/normalize-colors.ts",
    "deploy": "rm -rf .wrangler/deploy && cd dist/server && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "astro": "^6.1.1",
    "d3": "^7.9.0",
    "d3-geo": "^3.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@turf/turf": "^7.3.4",
    "tailwindcss": "4.2",
    "wrangler": "^4.79.0"
  }
}
